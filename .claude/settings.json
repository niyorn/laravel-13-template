{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-and-lint.sh",
                        "timeout": 30,
                        "statusMessage": "Formatting & linting edited file..."
                    }
                ]
            }
        ]
    }
}
